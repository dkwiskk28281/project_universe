VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Cloudflare Worker private OS hardening
EPI_PASSWORD=replace-with-private-password
SESSION_SECRET=replace-with-long-random-secret

# Cloudflare Access JWT validation.
# Example TEAM_DOMAIN: https://your-team.cloudflareaccess.com
TEAM_DOMAIN=
POLICY_AUD=

# Passkey / WebAuthn relying party.
# Public Worker example:
# PASSKEY_RP_ID=projectuniverse.chang2058.workers.dev
# PASSKEY_ORIGIN=https://projectuniverse.chang2058.workers.dev
PASSKEY_RP_NAME=Project Universe Think Tank
PASSKEY_RP_ID=
PASSKEY_ORIGIN=

# R2 raw-file vault is configured in wrangler.jsonc after a bucket exists:
# "r2_buckets": [{ "binding": "FILE_VAULT", "bucket_name": "your-private-vault" }]
