{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "projectuniverse",
  "main": "dist/_worker.js",
  "compatibility_date": "2026-06-21",
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    {
      "binding": "ce_data",
      "database_name": "ce_data"
    }
  ],
  "observability": {
    "enabled": true
  }
}
